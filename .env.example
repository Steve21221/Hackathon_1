# Use demo, ollama, openai, or claude. Ollama runs fully on this computer.
MODEL_PROVIDER=ollama

# Local Ollama settings. The Windows setup asks which model fits the computer.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:9b

# Optional OpenAI alternative. Never commit a real API key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional Anthropic Claude alternative. Never commit a real API key.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
