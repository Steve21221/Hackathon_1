# Use demo, ollama, or openai. Ollama runs fully on this computer.
MODEL_PROVIDER=ollama

# Local Ollama settings. The Windows setup asks which model fits the computer.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-r1:14b

# Optional OpenAI alternative. Never commit a real API key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
